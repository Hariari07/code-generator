[
  {
    "tableName": "employees",
    "dbName": "hlmmasters",
    "primaryKey": "id",
    "fields": [
      "id",
      "employeeCode",
      "employeePhoto",
      "name",
      "gender",
      "dob",
      "bloodGroup",
      "motherTongue",
      "readingLanguage",
      "speakingLanguage",
      "emailId",
      "contact",
      "emergencyContact",
      "doj",
      "designation",
      "department",
      "workingStatus",
      "dateOfExit",
      "preparedBy",
      "preparedAt",
      "approvedBy",
      "approvedAt",
      "stage"
    ],
    "frontend": {
      "formName": "employeeForm",
      "columns": 2,
      "fields": [
        { "fieldName": "employeeCode", "label": "Employee Code", "type": "number", "primengModule": "InputNumber", "required": true },
        { "fieldName": "name", "label": "Name", "type": "text", "primengModule": "InputText", "required": true },
        { "fieldName": "dob", "label": "Date of Birth", "type": "date", "primengModule": "DatePicker" },
        { "fieldName": "gender", "label": "Gender", "type": "text", "primengModule": "Select", "required": true, "options": ["Male", "Female", "Other"] },
        { "fieldName": "department", "label": "Department", "type": "text", "primengModule": "Select", "required": true, "options": ["HR", "IT", "Sales"] },
        { "fieldName": "designation", "label": "Designation", "type": "text", "primengModule": "InputText", "required": true }
      ]
    }
  },
  {
    "tableName": "customer_master",
    "dbName": "hlmmasters",
    "primaryKey": "id",
    "fields": [
      "id",
      "category",
      "partyName",
      "contactPerson",
      "mobileNo",
      "phoneNo",
      "emailId",
      "isMailSendActive",
      "dept",
      "preparedBy",
      "approvedBy",
      "approvalStatus",
      "isActive",
      "isStage"
    ],
    "frontend": {
      "formName": "customerForm",
      "columns": 2,
      "fields": [
        { "fieldName": "category", "label": "Category", "type": "text", "primengModule": "InputText", "required": true },
        { "fieldName": "partyName", "label": "Party Name", "type": "text", "primengModule": "InputText", "required": true },
        { "fieldName": "contactPerson", "label": "Contact Person", "type": "text", "primengModule": "InputText" },
        { "fieldName": "mobileNo", "label": "Mobile No", "type": "number", "primengModule": "InputNumber" },
        { "fieldName": "emailId", "label": "Email ID", "type": "email", "primengModule": "InputText" },
        { "fieldName": "dept", "label": "Department", "type": "text", "primengModule": "Select", "options": ["HR", "IT", "Sales"] }
      ]
    }
  }
]
